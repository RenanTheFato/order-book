generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id              String  @id @default(uuid())
  name            String
  last_name       String
  email           String  @unique
  hashed_password String
  balance         Decimal @default(0) @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}
